DirectoryIndex index.html

# Use a custom 404 page
ErrorDocument 404 /404.html

# Serve index.html as a fallback for single-page apps and ensure the
# server serves index.html as the directory default.
RewriteEngine On
# If a requested file or directory doesn't exist, rewrite to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
